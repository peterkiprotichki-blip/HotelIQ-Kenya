generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum RentiumUserRole {
  super_admin
  admin
  manager
  agent
  tenant
}

enum Permission {
  view_dashboard
  view_properties
  create_properties
  edit_properties
  delete_properties
  view_tenants
  create_tenants
  edit_tenants
  delete_tenants
  view_leases
  create_leases
  edit_leases
  delete_leases
  sign_lease
  view_payments
  create_payments
  edit_payments
  delete_payments
  view_damages
  create_damages
  edit_damages
  delete_damages
  view_reports
  export_reports
  view_users
  create_users
  edit_users
  delete_users
  create_maintenance_requests
  view_maintenance_requests
  edit_maintenance_requests
}

enum TenantPlan {
  free
  basic
  pro
  enterprise
}

enum FieldStage {
  planted
  growing
  ready
  harvested
}

enum FieldStatus {
  active
  at_risk
  completed
}

enum AuthProvider {
  credentials
  google
  local
}

model User {
  id                  String         @id @default(cuid())
  name                String
  email               String         @unique
  password            String         @default("")
  role                RentiumUserRole @default(agent)
  isActive            Boolean        @default(true)
  assignedPropertyIds  String[]       @default([])
  permissions         String[]       @default([])
  googleId            String         @default("")
  avatar              String         @default("")
  phone               String         @default("")
  isEmailVerified     Boolean        @default(false)
  verificationToken   String         @default("")
  isApproved          Boolean        @default(false)
  authProvider        AuthProvider   @default(credentials)
  tenantIds           String[]       @default([])
  activeTenantId      String         @default("")
  isDeleted           Boolean        @default(false)
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt

  @@index([googleId])
  @@index([activeTenantId])
  @@index([isDeleted])
}

model Property {
  id            String   @id @default(cuid())
  name          String
  county        String
  town          String
  address       String
  latitude      Float
  longitude     Float
  contactPhone  String
  contactEmail  String   @default("")
  ownerId       String   @unique
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Room {
  id          String   @id @default(cuid())
  propertyId  String
  roomNumber  String
  roomType    String
  basePrice   Float
  capacity    Int
  amenities   String[] @default([])
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([propertyId, roomNumber])
}

model Booking {
  id            String   @id @default(cuid())
  propertyId    String
  roomId        String
  guestName     String
  guestPhone    String
  guestEmail    String   @default("")
  checkIn       DateTime
  checkOut      DateTime
  status        String   @default("confirmed") // confirmed, checked-in, checked-out, cancelled, no-show
  totalPrice    Float
  pricePerNight Float
  source        String   @default("direct") // direct, walk-in, phone, referral
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model PricingSuggestion {
  id             String   @id @default(cuid())
  propertyId     String
  roomType       String
  date           DateTime
  suggestedPrice Float
  basePrice      Float
  demandScore    Float
  reasoning      String
  factorsUsed    String[] @default([])
  generatedAt    DateTime @default(now())
}

model KenyanEvent {
  id              String   @id @default(cuid())
  name            String
  description     String   @default("")
  category        String   // public-holiday, festival, sports, cultural, wildlife-season, conference
  startDate       DateTime
  endDate         DateTime
  county          String
  town            String
  latitude        Float
  longitude       Float
  regionRelevance String[] @default([])
  demandImpact    String   // low, medium, high
  isNational      Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  bookings        EventBooking[]
}

model EventBooking {
  id          String   @id @default(cuid())
  eventId     String
  guestName   String
  guestEmail  String
  guestPhone  String   @default("")
  bookedAt    DateTime @default(now())

  event       KenyanEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
}