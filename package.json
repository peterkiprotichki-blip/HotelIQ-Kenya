{
  "name": "hotel-IQ-kenya",
  "version": "1.0.0",
  "description": "HotelIQ Kenya - AI-powered lodge revenue platform",
  "private": true,
  "scripts": {
    "install:all": "npm install && cd \"hotel-IQ kenya-backend\" && npm install && cd ../\"hotel-IQ kenya-frontend\" && npm install",
    "start:backend": "cd \"hotel-IQ kenya-backend\" && npm run dev",
    "start:frontend": "cd \"hotel-IQ kenya-frontend\" && npm start",
    "build:backend": "cd \"hotel-IQ kenya-backend\" && npm run build",
    "build:frontend": "cd \"hotel-IQ kenya-frontend\" && npm run build",
    "test:backend": "cd \"hotel-IQ kenya-backend\" && npm test",
    "test:frontend": "cd \"hotel-IQ kenya-frontend\" && npm test"
  },
  "keywords": [
    "hospitality",
    "hotel-management",
    "pricing-ai",
    "kenya"
  ],
  "author": "HotelIQ Kenya Team",
  "license": "MIT"
}
