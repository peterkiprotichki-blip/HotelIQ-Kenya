generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum RentiumUserRole {
  super_admin
  admin
  manager
  agent
  tenant
}

enum Permission {
  view_dashboard
  view_properties
  create_properties
  edit_properties
  delete_properties
  view_tenants
  create_tenants
  edit_tenants
  delete_tenants
  view_leases
  create_leases
  edit_leases
  delete_leases
  sign_lease
  view_payments
  create_payments
  edit_payments
  delete_payments
  view_damages
  create_damages
  edit_damages
  delete_damages
  view_reports
  export_reports
  view_users
  create_users
  edit_users
  delete_users
  create_maintenance_requests
  view_maintenance_requests
  edit_maintenance_requests
}

enum TenantPlan {
  free
  basic
  pro
  enterprise
}

enum FieldStage {
  planted
  growing
  ready
  harvested
}

enum FieldStatus {
  active
  at_risk
  completed
}

enum AuthProvider {
  credentials
  google
  local
}

model User {
  id                  String         @id @default(cuid())
  name                String
  email               String         @unique
  password            String         @default("")
  role                RentiumUserRole @default(agent)
  isActive            Boolean        @default(true)
  assignedPropertyIds  String[]       @default([])
  permissions         String[]       @default([])
  googleId            String         @default("")
  avatar              String         @default("")
  phone               String         @default("")
  isEmailVerified     Boolean        @default(false)
  verificationToken   String         @default("")
  isApproved          Boolean        @default(false)
  authProvider        AuthProvider   @default(credentials)
  tenantIds           String[]       @default([])
  activeTenantId      String         @default("")
  isDeleted           Boolean        @default(false)
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt

  @@index([googleId])
  @@index([activeTenantId])
  @@index([isDeleted])
}

model Tenant {
  id              String      @id @default(cuid())
  name            String
  slug            String      @unique
  domain          String      @default("")
  logoUrl         String      @default("")
  isActive        Boolean     @default(true)
  plan            TenantPlan  @default(free)
  settings        Json?
  ownerUserId     String
  contactEmail    String      @default("")
  billingEmail    String      @default("")
  maxUsers        Int         @default(0)
  maxProperties   Int         @default(0)
  mpesaClientId   String      @default("")
  isDeleted       Boolean     @default(false)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@index([ownerUserId])
  @@index([isActive])
  @@index([isDeleted])
}

model Field {
  id                  String      @id @default(cuid())
  name                String
  cropType            String
  plantingDate        DateTime
  currentStage        FieldStage  @default(planted)
  status              FieldStatus @default(active)
  assignedAgentId     String
  description         String      @default("")
  areaSize            Float       @default(0)
  location            String      @default("")
  notes               String[]    @default([])
  expectedHarvestDate DateTime?
  updatedBy           String?
  isDeleted           Boolean     @default(false)
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt

  @@index([assignedAgentId])
  @@index([isDeleted])
}